import tkinter as tk
import json


class Task:
    def __init__(self, title, due_date, priority):
        self.title = title
        self.due_date = due_date
        self.priority = priority


class TaskManager:
    def __init__(self):
        self.tasks = []


class StudyPlannerApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Study Planner")
        self.root.geometry("700x500")

        self.task_manager = TaskManager()

        self.show_start_screen()

    def clear_window(self):
        for widget in self.root.winfo_children():
            widget.destroy()

    def show_start_screen(self):
        self.clear_window()

        tk.Label(
            self.root,
            text="Study Planner",
            font=("Arial", 24, "bold")
        ).pack(pady=20)

        tk.Button(
            self.root,
            text="Main Dashboard",
            command=self.show_dashboard
        ).pack(pady=10)

        tk.Button(
            self.root,
            text="Exit",
            command=self.root.quit
        ).pack(pady=10)

    def show_dashboard(self):
        self.clear_window()

        tk.Label(
            self.root,
            text="Main Dashboard",
            font=("Arial", 20)
        ).pack(pady=20)


root = tk.Tk()
app = StudyPlannerApp(root)
root.mainloop()